# ── Supabase ─────────────────────────────────────────
# Project URL and anon key from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ── Database (Supabase Postgres) ─────────────────────
# DATABASE_URL: pooled connection (port 6543, pgbouncer=true) — used at runtime.
# DIRECT_URL:   TRUE direct connection (db.*.supabase.co:5432, no PgBouncer) — used by
#               Prisma migrations and seed. Must NOT go through the session pooler,
#               as Prisma's adapter-pg uses BEGIN+SET which PgBouncer blocks.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# ── App ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
